# IncusAdmin Environment Configuration
# Copy to /etc/incus-admin/incus-admin.env and fill in values
#
# Production 必填项（INCUS_ADMIN_ENV=production 默认；启动会校验）：
#   - SSH_KNOWN_HOSTS_FILE
#   - CLUSTER_CA_FILE（每个 cluster 都要）
#   - PASSWORD_ENCRYPTION_KEY
# 三项任一缺失启动 fail（PLAN-051 §2-A / W1+W2+W3）。

# 运行环境：production / dev / test。
# production 触发 fail-fast 校验；dev / test 跳过校验便于本地运行。
INCUS_ADMIN_ENV=production

# Server
LISTEN=:8080
# IMPORTANT: EMERGENCY_LISTEN 必须 bind 127.0.0.1（loopback）。
# 这是带外应急通道，设计为 oauth2-proxy / Logto 不可用时的兜底登录路径。
# 接入方式：运维通过 SSH tunnel 转发本地端口 →
#   ssh -L 8081:127.0.0.1:8081 server
# 然后浏览器开 http://localhost:8081/auth/emergency 输入 EMERGENCY_TOKEN。
# 任何把它绑到 0.0.0.0 / 公网网卡的部署都属于配置错误（绕过 oauth2-proxy）。
EMERGENCY_LISTEN=127.0.0.1:8081
# 部署拓扑（PLAN-051 §2-B / pma-cr M-2）：
#   single-instance（默认）：进程内 pkceStore + emergency rate-limit buckets 工作正常
#   multi-instance：启动会打 warn——pkceStore 不跨实例，step-up callback 命中
#                   不同实例时会失败；负载均衡需 sticky session 或外置 store
#                   （OPS-047 backlog 跟踪 DB/Redis 升级）
DEPLOYMENT_TOPOLOGY=single-instance
DOMAIN=vmc.5ok.co

# Database
DATABASE_URL=postgres://incusadmin:CHANGE_ME@localhost/incusadmin?sslmode=disable

# Auth
ADMIN_EMAILS=ai@5ok.co
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_32
EMERGENCY_TOKEN=GENERATE_WITH_openssl_rand_hex_32

# Step-up OIDC（敏感操作二次认证）。四项必须一起配；任一缺失整个 step-up
# 子系统 disabled，敏感路由 fallback 到 permissive 模式（仅 warn）。
# 生产强烈建议配上。
OIDC_ISSUER=https://auth.l.5ok.co/oidc
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
STEPUP_CALLBACK_URL=https://vmc.5ok.co/api/auth/stepup-callback
# step-up max-age：完成重认证后多久内可执行敏感操作。Logto 端 max_age=0
# 每次重认证；后端用此值校验 auth_time 新鲜度。
STEPUP_MAX_AGE=5m

# 跨协议密钥独立（Session-1 O2 推荐）。空值回退 SESSION_SECRET（向后兼容）。
# 生产建议三个独立 secret，每个用 openssl rand -base64 32 生成：
STEPUP_STATE_SECRET=
SHADOW_SESSION_SECRET=

# 审计日志保留期（天）。<=0 disable cleanup。
AUDIT_RETENTION_DAYS=365

# Emergency cookie 旧 2-part 格式 (email|hmac，无 TTL) 截止期。RFC3339 时间戳。
# Session-1 W7 升级到新 3-part 格式 (email|exp|hmac，10min TTL) 后，旧格式
# 仍向后兼容。建议初次部署设为今天 +30 天，过期后强制只接受新格式：
#   EMERGENCY_LEGACY_DEADLINE=2026-06-09T00:00:00Z
# 留空表示无截止（grace 期持续）。改后须重启进程生效（sync.Once 缓存）。
EMERGENCY_LEGACY_DEADLINE=

# 限流分级（PLAN-051 §2-B / W4）：
#   - 默认 30/min（/api/portal）
#   - 高敏 5/min（/api/auth/stepup/* + /api/admin/users:batch + /shadow/*）
# X-Forwarded-For 真实 IP 信任白名单，用于登录前阶段 key（CIDR 列表，逗号分隔）。
# 留空 = 不信任任何前置代理（RemoteAddr 取 raw socket peer）。
# 生产部署 Cloudflare 时填入 CF 网段；nginx 反代时填 nginx 内网。
TRUSTED_PROXIES=

# Jobs runtime graceful shutdown 超时（PLAN-051 §2-A / F-04）。SIGTERM 后等
# in-flight provisioning job 多久。默认 30s。改 120s 给 image-pull 留时间。
JOBS_GRACEFUL_TIMEOUT=30s

# VM 密码字段加密（OPS-022 / W3）。32 字节 base64：
#   openssl rand -base64 32
# 生产必须配置；空值 + Env=production 启动会 fail。
PASSWORD_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_base64_32

# Cluster（首个 / 默认 cluster；env-bootstrap 路径，启动后写 DB，admin
# 之后通过 UI 加更多 cluster 即可）。CLUSTER_API_URL 留空 → 跳过 env
# bootstrap，全部走 DB（重启时从 clusters 表加载）。
#
# Production 强校验：CLUSTER_CA_FILE 必须非空（PLAN-051 W2）。空值 +
# Env=production 启动 fail；非 production 时 fallback 到 InsecureSkipVerify
# + SPKI TOFU pin（首次连接学指纹）。
CLUSTER_NAME=default
CLUSTER_DISPLAY_NAME=Default Cluster
CLUSTER_API_URL=https://incus.l.5ok.co:8443
CLUSTER_CERT_FILE=/etc/incus-admin/certs/client.crt
CLUSTER_KEY_FILE=/etc/incus-admin/certs/client.key
CLUSTER_CA_FILE=/etc/incus-admin/certs/cluster-ca.pem
CLUSTER_DEFAULT_PROJECT=customers
CLUSTER_STORAGE_POOL=ceph-pool
CLUSTER_NETWORK=br-pub

# Cluster IP 池（首段示例；多段配 CLUSTER_IP_POOLS_JSON）。
# CLUSTER_IP_RANGE: ip-range 字符串如 "x.y.z.10-x.y.z.250"
# CLUSTER_IP_CIDR: 子网 CIDR 如 "x.y.z.0/24"
# CLUSTER_IP_GATEWAY: 网关 IP
CLUSTER_IP_RANGE=
CLUSTER_IP_CIDR=
CLUSTER_IP_GATEWAY=
# 多 IP 池：JSON 数组，结构 [{"name":"public","cidr":"...","range":"...","gateway":"..."}]
# 优先级高于单段 CLUSTER_IP_* 三件套。
CLUSTER_IP_POOLS_JSON=

# 调度权重（PLAN-039 / OPS-042）。JSON 形如
#   {"cpu":1,"memory":2,"disk":1,"running_vms":3}
# 留空走默认权重。
SCHEDULER_WEIGHTS=

# Billing
BILLING_CURRENCY=USD

# Monitoring (optional, via WireGuard)
PROMETHEUS_URL=http://10.0.20.1:9090
GRAFANA_URL=http://10.0.20.1:3000

# Prometheus exposition 端点鉴权（PLAN-041 / INFRA-009）。空值 = 匿名（任何
# 客户端能 GET /api/metrics）；非空 = 强制 Bearer 校验。生产部署建议配。
METRICS_BEARER_TOKEN=

# AI Provider（PLAN-038 / OPS-041 LLM 角色推荐 + 失败诊断）。
# AI_PROVIDER=anthropic 时 AI_API_KEY 必须配；disabled 全路径 503，前端隐藏
# AI 入口。AI_BASE_URL 给自托管 OpenAI 兼容 endpoint 用（anthropic 留空）。
AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=claude-haiku-4-5
AI_BASE_URL=
AI_REQUEST_TIMEOUT_SEC=30
AI_MONTHLY_TOKEN_BUDGET=0

# 异步 provisioning runtime 容量（OPS-050）。
# PoolSize=worker 池；QueueSize=入队 channel buffer。
# 默认 4 / 64 适配单机小流量；促销 / 批量场景建议 8 / 256。
# 队列满后 Enqueue 阻塞 HTTP（PayWithBalance 已 commit、余额已扣的状态下挂死），
# 调大 QueueSize 是最直接的缓解。不建议 PoolSize > 16，单 Incus host 镜像并发
# 拉取超过 16 会撞网络/磁盘瓶颈。运行期 30s 一次 slog `provisioning queue depth`
# （仅 depth > 0 时输出）。
JOBS_POOL_SIZE=4
JOBS_QUEUE_SIZE=64

# Ceph 远程管理 SSH（可选，仅启用 Ceph 仪表板时需要）
CEPH_SSH_HOST=
CEPH_SSH_USER=root
CEPH_SSH_KEY=/etc/incus-admin/certs/ssh_key

# SSH 主机密钥校验（强烈建议生产启用）
# 文件存在则对 Ceph/节点远程执行启用严格 HostKeyCallback；为空则回退
# InsecureIgnoreHostKey 并打 warn（便于历史部署过渡，但不应用于生产）。
# 生成示例：ssh-keyscan -H <host1> <host2> > /etc/incus-admin/known_hosts
SSH_KNOWN_HOSTS_FILE=/etc/incus-admin/known_hosts
