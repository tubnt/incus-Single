# ======================
# Paymenter 部署环境变量
# ======================
# 使用前请复制为 .env 并填写所有值
# 密钥类字段请使用 openssl rand -base64 24 生成

# --- 应用 ---
APP_NAME=Paymenter
DOMAIN=panel.example.com
# php artisan key:generate 生成，格式: base64:xxxxx
APP_KEY=<GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE>

# --- 数据库 ---
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
MYSQL_ROOT_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- Redis ---
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- SMTP 邮件 ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=<SMTP_PASSWORD>
MAIL_FROM_ADDRESS=noreply@example.com

# --- Let's Encrypt ---
CERTBOT_EMAIL=admin@example.com

# --- Incus API（mTLS） ---
# API 端点（通过 WireGuard 隧道连接）
INCUS_API_ENDPOINT=https://10.0.10.1:8443
# mTLS 客户端证书（容器内路径，对应 docker-compose 中 ./certs 挂载）
INCUS_CERT_FILE=/var/www/html/certs/client.crt
INCUS_KEY_FILE=/var/www/html/certs/client.key
INCUS_CA_FILE=/var/www/html/certs/ca.crt
# Incus Project 名称
INCUS_PROJECT=customers
# 存储池
INCUS_STORAGE_POOL=ceph-pool

# --- WireGuard 隧道 ---
# Paymenter 端隧道 IP
WG_ADDRESS=10.100.0.1/24
# Incus 集群管理网段路由
WG_ALLOWED_IPS=10.0.10.0/24
