  "panels": [
    {
      "title": "VM vCPU 使用时间",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(incus_cpu_seconds_total[5m])",
          "legendFormat": "{{ name }} cpu{{ cpu }}"
        }
      ]
    },
    {
      "title": "VM 内存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "incus_memory_Active_bytes",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "title": "VM 磁盘读写",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(incus_disk_read_bytes_total[5m])",
          "legendFormat": "{{ name }} 读"
        },
        {
          "expr": "rate(incus_disk_written_bytes_total[5m])",
          "legendFormat": "{{ name }} 写"
        }
      ]
    },
    {
      "title": "VM 网络流量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(incus_network_receive_bytes_total[5m])",
          "legendFormat": "{{ name }} 入"
        },
        {
          "expr": "rate(incus_network_transmit_bytes_total[5m])",
          "legendFormat": "{{ name }} 出"
        }
      ]
    },
    {
      "title": "运行中 VM 数量（按节点）",
      "type": "stat",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "expr": "count by(node_name) (incus_cpu_seconds_total{cpu=\"0\"})",
          "legendFormat": "{{ node_name }}"
        }
      ]
    }
  ],
